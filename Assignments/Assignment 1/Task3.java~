import java.util.Scanner;
public class Task3{
  public static void main(String[]args){
    Scanner sc = new Scanner(System.in);
    System.out.print("Enter the length of the array: ");
    int n = sc.nextInt();
    int [] arr1 = new int[n];
    for(int i =0; i<n; i++){
      arr1[i] = sc.nextInt();
    }
    int straightInd = 0;
    for(int i =n-1; i>=0; i--){
      int temp = 0;
      temp = arr1[straightInd];
      arr1[straightInd] = arr1[i];
      arr1[i]=temp;
      straightInd++;
    }
  }
}